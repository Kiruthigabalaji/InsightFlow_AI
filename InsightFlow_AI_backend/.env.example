# ── InsightFlow AI — Environment variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# LLM (required for extraction agent)
ANTHROPIC_API_KEY=sk-ant-...

# Financial data API (required for FMP collector)
FMP_API_KEY=...

# BigQuery (optional — pipeline runs without it)
BQ_PROJECT=your-gcp-project-id
BQ_DATASET=insightflow
BQ_TABLE=cre_records
BQ_AUDIT_TABLE=audit_log

# CORS — comma-separated list of allowed frontend origins
# Leave blank or set to * to allow all origins (development only)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Extraction batch size (records per Claude API call)
EXTRACTION_BATCH_SIZE=5

# Runtime environment
ENV=production
